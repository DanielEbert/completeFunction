{
  "name": "completefunction",
  "displayName": "completeFunction",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "OpenCode",
      "properties": {
        "opencode.model": {
          "type": "string",
          "default": "google/gemini-3.1-pro-preview",
          "description": "The AI model to use for OpenCode"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-sidebar",
          "title": "OpenCode",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "opencode-sidebar": [
        {
          "id": "opencode.tasks",
          "name": "Requests"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode.completeFunction",
        "title": "OpenCode: Complete Current Function"
      },
      {
        "command": "opencode.showOutput",
        "title": "Show Output",
        "icon": "$(output)"
      },
      {
        "command": "opencode.jumpToImplementation",
        "title": "Jump to Implementation",
        "icon": "$(go-to-file)"
      },
      {
        "command": "opencode.cancelTask",
        "title": "Cancel Task",
        "icon": "$(stop)"
      },
      {
        "command": "opencode.selectModel",
        "title": "Select Model",
        "icon": "$(hubot)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "opencode.selectModel",
          "when": "view == opencode.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "opencode.jumpToImplementation",
          "when": "view == opencode.tasks"
        },
        {
          "command": "opencode.cancelTask",
          "when": "view == opencode.tasks && viewItem == running",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencode.completeFunction",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.117.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}